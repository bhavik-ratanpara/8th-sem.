
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Cooking Lab application, storing their profile information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User, matching their Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of account creation.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last profile update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "displayName",
        "createdAt"
      ]
    },
    "SavedRecipe": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavedRecipe",
      "type": "object",
      "description": "A recipe saved by a user to their private collection.",
      "properties": {
        "id": { "type": "string" },
        "recipeName": { "type": "string" },
        "cuisine": { "type": "string" },
        "servings": { "type": "number" },
        "dietType": { "type": "string", "enum": ["Vegetarian", "Non-Vegetarian"] },
        "language": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array", "items": { "type": "string" } },
        "generatedAt": { "type": "object" },
        "isFavourite": { "type": "boolean" }
      },
      "required": ["recipeName", "cuisine", "servings", "dietType", "ingredients", "steps", "isFavourite"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/users/{userId}/savedRecipes/{recipeId}",
        "definition": {
          "entityName": "SavedRecipe",
          "schema": { "$ref": "#/backend/entities/SavedRecipe" },
          "description": "Private recipes saved by the user."
        }
      }
    ]
  }
}
